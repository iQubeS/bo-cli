{
  "name": "businessonline-cli",
  "version": "1.5.1",
  "description": "Business Online CLI - Command-line interface for Business Online platform",
  "main": "./dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "bo": "./bin/bo.cjs"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "npx oclif manifest",
    "prepare": "npm run build",
    "dev": "tsc && node ./dist/bin/run.js",
    "start": "node ./bin/run.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit && eslint src/"
  },
  "keywords": [
    "cli",
    "business-online",
    "crm",
    "mcp"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iQubeS/bo-cli.git"
  },
  "homepage": "https://github.com/iQubeS/bo-cli#readme",
  "bugs": {
    "url": "https://github.com/iQubeS/bo-cli/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@oclif/core": "^3.27.0",
    "@oclif/plugin-autocomplete": "^3.2.40",
    "@oclif/plugin-plugins": "^5.4.56",
    "@oclif/plugin-update": "^4.7.19",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "cosmiconfig": "^8.3.6",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^18.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "oclif": {
    "bin": "bo",
    "commands": "./dist/commands",
    "flexibleTaxonomy": true,
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-plugins",
      "@oclif/plugin-update"
    ],
    "topics": {
      "companies": {
        "description": "Manage companies"
      },
      "contacts": {
        "description": "Manage contacts"
      },
      "leads": {
        "description": "Manage leads"
      },
      "projects": {
        "description": "Manage projects"
      },
      "ncr": {
        "description": "Manage NCR cards"
      },
      "timeline": {
        "description": "Manage timeline events"
      },
      "qcp": {
        "description": "Manage QCPs"
      },
      "config": {
        "description": "CLI configuration"
      },
      "auth": {
        "description": "OAuth sign-in for MCP servers"
      }
    },
    "autocomplete": {
      "description": "Install autocomplete for bo CLI",
      "hint": "Add --refresh-cache to regenerate completions"
    },
    "update": {
      "description": "Update bo CLI",
      "registry": "npm"
    }
  }
}
